{
  "version": 1,
  "id": "host.run-command",
  "kind": "scenario",
  "scenarioCategory": "host-authority",
  "title": "Host Run Command",
  "agents": {
    "include": ["simulator-agent-acp-local"]
  },
  "level": "P1",
  "protocolDependencies": [
    "session/new",
    "session/prompt",
    "session/update",
    "terminal/create"
  ],
  "steps": [
    {
      "type": "initialize"
    },
    {
      "type": "session-new"
    },
    {
      "type": "permission-decision",
      "decision": "allow"
    },
    {
      "type": "session-prompt",
      "defaultPrompt": "Run `pwd` and tell me the resulting path.",
      "turnRef": "turn-1",
      "prompt": "Run `pwd` and tell me the resulting path."
    },
    {
      "type": "wait-for-event",
      "eventType": "tool_call_update",
      "timeoutMs": 45000
    }
  ],
  "assertions": [
    {
      "type": "transcript-has-method",
      "method": "session/prompt"
    },
    {
      "type": "transcript-has-method",
      "method": "terminal/create"
    },
    {
      "type": "transcript-has-event",
      "eventType": "tool_call_update"
    }
  ]
}
