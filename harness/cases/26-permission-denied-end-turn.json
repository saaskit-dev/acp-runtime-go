{
  "version": 1,
  "id": "scenario.permission-denied-end-turn",
  "kind": "scenario",
  "agents": {
    "include": [
      "simulator-agent-acp-local"
    ]
  },
  "probes": {
    "simulator-agent-acp-local": {
      "prompt": "/write /tmp/acp-harness-test.txt hello world"
    }
  },
  "title": "Permission Denied Outcome (End Turn)",
  "level": "P1",
  "protocolDependencies": [
    "session/new",
    "session/prompt",
    "session/request_permission"
  ],
  "steps": [
    {
      "type": "initialize"
    },
    {
      "type": "session-new"
    },
    {
      "type": "permission-decision",
      "decision": "deny"
    },
    {
      "type": "session-prompt",
      "prompt": "$probe-prompt",
      "turnRef": "turn-deny-end-turn"
    },
    {
      "type": "wait-for-event",
      "eventType": "completed",
      "timeoutMs": 45000
    }
  ],
  "assertions": [
    {
      "type": "transcript-has-method",
      "method": "session/request_permission"
    },
    {
      "type": "transcript-method-response-has",
      "method": "session/prompt",
      "path": "stopReason",
      "equals": "end_turn"
    },
    {
      "type": "transcript-event-count",
      "eventType": "tool_call_update",
      "min": 1
    },
    {
      "type": "transcript-event-field",
      "eventType": "tool_call_update",
      "path": "update.status",
      "equals": "failed"
    }
  ]
}
